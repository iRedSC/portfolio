---
import { markdownToPlainText, renderMarkdown } from '../../lib/render-markdown';

interface Props {
	href: string;
	note?: string;
	buttonName?: string;
}

const { href, note, buttonName = 'Live demo' } = Astro.props;
const noteHtml = note ? await renderMarkdown(note) : undefined;
const notePlain = note ? markdownToPlainText(note) : undefined;
const ariaLabel = notePlain ? `${buttonName} — ${notePlain}` : buttonName;
const modalId = `project-demo-modal-${Math.random().toString(36).slice(2, 9)}`;
---

{note ? (
	<div class="project-demo-link-with-note">
		<button
			type="button"
			class="post-project-demo-link project-demo-link-trigger"
			aria-label={ariaLabel}
			aria-haspopup="dialog"
			aria-controls={modalId}
		>
			{buttonName}
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
				<polyline points="15 3 21 3 21 9"></polyline>
				<line x1="10" y1="14" x2="21" y2="3"></line>
			</svg>
		</button>

		<div
			id={modalId}
			class="project-demo-modal"
			role="dialog"
			aria-modal="true"
			aria-labelledby={`${modalId}-title`}
			hidden
		>
			<button type="button" class="project-demo-modal-backdrop" aria-label="Close dialog" tabindex="-1"></button>
			<div class="project-demo-modal-panel">
				<button type="button" class="project-demo-modal-close" aria-label="Close">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
				<div id={`${modalId}-title`} class="project-demo-modal-note" set:html={noteHtml} />
				<a
					href={href}
					class="post-project-demo-link project-demo-modal-link"
					target="_blank"
					rel="noreferrer"
				>
					{buttonName}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
			</div>
		</div>
	</div>
) : (
	<a
		href={href}
		class="post-project-demo-link"
		target="_blank"
		rel="noreferrer"
		aria-label={ariaLabel}
	>
		{buttonName}
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
			<polyline points="15 3 21 3 21 9"></polyline>
			<line x1="10" y1="14" x2="21" y2="3"></line>
		</svg>
	</a>
)}

<style>
	.project-demo-link-trigger {
		cursor: pointer;
		font-family: inherit;
	}

	.project-demo-modal {
		position: fixed;
		inset: 0;
		z-index: 99999;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
	}

	.project-demo-modal[hidden] {
		display: none;
	}

	.project-demo-modal-backdrop {
		position: absolute;
		inset: 0;
		z-index: 0;
		border: none;
		padding: 0;
		margin: 0;
		background: rgba(0, 0, 0, 0.45);
		cursor: pointer;
	}

	.project-demo-modal-panel {
		position: relative;
		z-index: 1;
		width: min(100%, 24rem);
		padding: 1.25rem 1rem 1rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 16px;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
		animation: project-demo-modal-enter 0.2s ease-out;
	}

	.project-demo-modal-close {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: none;
		border-radius: 8px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition: color 0.15s ease, background 0.15s ease;
	}

	.project-demo-modal-close:hover {
		color: var(--text);
		background: var(--border);
	}

	.project-demo-modal-close svg {
		width: 1.125rem;
		height: 1.125rem;
	}

	.project-demo-modal-note {
		margin: 0 2rem 1rem 0;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--text);
		text-align: left;
	}

	.project-demo-modal-note :global(p) {
		margin: 0;
	}

	.project-demo-modal-note :global(p + p),
	.project-demo-modal-note :global(p + ul),
	.project-demo-modal-note :global(p + ol),
	.project-demo-modal-note :global(ul + p),
	.project-demo-modal-note :global(ol + p) {
		margin-top: 0.75rem;
	}

	.project-demo-modal-note :global(ul),
	.project-demo-modal-note :global(ol) {
		margin: 0;
		padding-left: 1.25rem;
	}

	.project-demo-modal-note :global(li + li) {
		margin-top: 0.35rem;
	}

	.project-demo-modal-note :global(code) {
		font-family: 'Fira Code', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			'Liberation Mono', 'Courier New', monospace;
		font-size: 0.875em;
	}

	.project-demo-modal-note :global(a) {
		color: var(--accent);
	}

	.project-demo-modal-link {
		width: 100%;
	}

	@keyframes project-demo-modal-enter {
		from {
			opacity: 0;
			transform: scale(0.96) translateY(0.5rem);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}
</style>

<script>
	function initProjectDemoModals() {
		document.querySelectorAll('.project-demo-link-with-note').forEach((wrap) => {
			if (wrap.hasAttribute('data-demo-modal-init')) return;
			wrap.setAttribute('data-demo-modal-init', '');

			const trigger = wrap.querySelector<HTMLButtonElement>('.project-demo-link-trigger');
			const modal = wrap.querySelector<HTMLElement>('.project-demo-modal');
			const backdrop = wrap.querySelector<HTMLButtonElement>('.project-demo-modal-backdrop');
			const closeBtn = wrap.querySelector<HTMLButtonElement>('.project-demo-modal-close');

			if (!trigger || !modal) return;

			let lastFocus: HTMLElement | null = null;
			let modalHome: HTMLElement | null = null;

			const open = () => {
				lastFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
				if (modal.parentElement !== document.body) {
					modalHome = modal.parentElement instanceof HTMLElement ? modal.parentElement : wrap;
					document.body.appendChild(modal);
				}
				modal.hidden = false;
				document.body.style.overflow = 'hidden';
				closeBtn?.focus();
			};

			const close = () => {
				modal.hidden = true;
				document.body.style.overflow = '';
				if (modalHome && modal.parentElement === document.body) {
					modalHome.appendChild(modal);
				}
				lastFocus?.focus();
			};

			trigger.addEventListener('click', open);
			closeBtn?.addEventListener('click', close);
			backdrop?.addEventListener('click', close);

			modal.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') close();
			});
		});
	}

	initProjectDemoModals();
	document.addEventListener('astro:after-swap', initProjectDemoModals);
</script>
