---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { SocialLink } from '../../lib/socials';
import { layoutSocialOrbit } from '../../lib/socials';

interface Props {
	profileLight: ImageMetadata;
	profileDark: ImageMetadata;
	socialLinks: SocialLink[];
}

const { profileLight, profileDark, socialLinks } = Astro.props;
const orbitPositions = layoutSocialOrbit(socialLinks.length);
---

<div class="hero-photo-orbit">
	<div class="hero-photo">
		<Image
			src={profileLight}
			alt="Portrait"
			class="hero-photo__img hero-photo__img--light"
			width={420}
			height={563}
		/>
		<Image
			src={profileDark}
			alt=""
			class="hero-photo__img hero-photo__img--dark"
			width={420}
			height={563}
			aria-hidden="true"
		/>
	</div>

	{
		socialLinks.length > 0 && (
			<ul class="hero-social-orbit" aria-label="Social links">
				{socialLinks.map((link, index) => {
					const position = orbitPositions[index];
					const radians = (position.angle * Math.PI) / 180;
					const x = Math.cos(radians) * position.radius;
					const y = Math.sin(radians) * position.radius;
					const tilt = Math.max(-14, Math.min(14, (position.angle + 180) * 0.12));

					return (
						<li
							class="hero-social-orbit__item"
							style={`--orbit-x: ${x.toFixed(2)}px; --orbit-y: ${y.toFixed(2)}px; --orbit-tilt: ${tilt.toFixed(2)}deg; --orbit-delay: ${position.delay}s;`}
						>
							<a
								href={link.link}
								target="_blank"
								rel="noopener noreferrer"
								class="hero-social-orbit__link"
								style={`--icon-url: url(${link.icon});`}
								aria-label={link.name}
							>
							</a>
						</li>
					);
				})}
			</ul>
		)
	}
</div>
