---
import FloatingNav from './FloatingNav';
import { getSiteConfig } from '../lib/site-config';

const { sections } = await getSiteConfig();

const navLinks = [
	{ href: '/resume', label: 'Resume' },
	{ href: '/blog', label: 'Blog' },
	...(sections.projects ? [{ href: '/projects', label: 'Projects' }] : []),
	...(sections.caseStudies ? [{ href: '/case-studies', label: 'Cases' }] : []),
	...(sections.tldrs ? [{ href: '/tldrs', label: 'TLDRs' }] : []),
];
const currentPath = Astro.url.pathname;

const linksWithActive = navLinks.map((link) => ({
	...link,
	isActive:
		currentPath === link.href ||
		(link.href !== '/' && currentPath.startsWith(link.href + '/')),
}));
---

<FloatingNav client:load links={linksWithActive} />
