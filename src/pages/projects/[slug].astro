---
import Layout from '../../layouts/Layout.astro';
import PostBanner from '../../components/PostBanner.astro';
import PostToc from '../../components/PostToc.astro';
import TocScrollSpy from '../../components/TocScrollSpy';
import { getCollection } from 'astro:content';
import { getSiteConfig } from '../../lib/site-config';
import { getCommitActivity } from '../../lib/github';
import CommitHeatmap from '../../components/ui/CommitHeatmap.astro';
import Tag from '../../components/ui/Tag.astro';
import ProjectDemoLink from '../../components/ui/ProjectDemoLink.astro';

export const prerender = true;

export async function getStaticPaths() {
	const { sections } = await getSiteConfig();
	if (!sections.projects) return [];

	const entries = await getCollection('projects', ({ data }) => !data.draft);
	return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;

const { sections } = await getSiteConfig();
if (!sections.projects || !entry) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}
const { Content, headings } = await entry.render();
const commitActivity = await getCommitActivity(entry.data.githubRepo);
const toc = headings
	.filter((heading) => heading.depth === 2 || heading.depth === 3)
	.map((heading) => ({
		depth: heading.depth,
		slug: heading.slug,
		text: heading.text,
	}));
const buildDate = new Date().toLocaleDateString();
const bannerImage = entry.data.thumbnail ?? entry.data.image;
---

<Layout title={entry.data.title} description={entry.data.description} image={bannerImage}>
	<article class:list={['post', bannerImage && 'post--has-banner']}>
		{bannerImage && <PostBanner src={bannerImage} />}
		<header class="post-hero">
			<div class="post-hero-content">
				<p class="eyebrow">{entry.data.pubDate.toLocaleDateString()}</p>
				<div class="post-project-title-row">
					<h1>{entry.data.title}</h1>
					<div class="post-project-external">
						<a
							href={entry.data.repoUrl}
							class="post-project-icon-link"
							target="_blank"
							rel="noreferrer"
							aria-label="GitHub repository"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path
									d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
								></path>
							</svg>
						</a>
						{entry.data.demoUrl && (
							<ProjectDemoLink
								href={entry.data.demoUrl}
								note={entry.data.demoNote}
								buttonName={entry.data.demoButtonName}
							/>
						)}
					</div>
				</div>
				<p class="lead">{entry.data.description}</p>
				<div>
					{entry.data.tags.map((tag) => (
						<Tag label={tag} />
					))}
				</div>
				<div class="post-commit-activity">
					<CommitHeatmap days={commitActivity.days} />
					<p class="meta">Commit activity last updated: {buildDate}</p>
				</div>
			</div>
		</header>
		<div class="post-body">
			{toc.length > 0 && <PostToc items={toc} />}
			<div class="post-content">
				<Content />
			</div>
		</div>
	</article>
	{toc.length > 0 && <TocScrollSpy client:load />}
</Layout>

<style>
	.post-commit-activity {
		max-width: 420px;
		margin-top: 1.25rem;
	}

	.post-commit-activity .meta {
		margin: 0.35rem 0 0;
	}
</style>