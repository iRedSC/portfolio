---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';
---

<Layout
  title="Resume"
  description="Mason Trout — Full-Stack Software Engineer. Experience, projects, and skills."
>
  <article class="resume">
    <div class="resume-toolbar">
      <button type="button" class="button button-primary" id="print-resume">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15V3"/><path d="m7 10 5 5 5-5"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/></svg>
        Save as PDF
      </button>
    </div>

    <div class="resume-page">
      <header class="resume-header">
        <div>
          <h1>Mason Trout</h1>
          <div class="resume-role">Full-Stack Software Engineer</div>
        </div>
        <div class="resume-contact">
          <div>Harrisburg, PA</div>
          <div><a href="https://masonltrout.me">masonltrout.me</a></div>
          <div>
            <a href="https://github.com/iRedSC">github.com/iRedSC</a><span class="sep" aria-hidden="true">&middot;</span><a href="https://linkedin.com/in/masonltrout">linkedin.com/in/masonltrout</a>
          </div>
        </div>
      </header>

      <section class="resume-section resume-summary">
        <h2>Summary</h2>
        <p>Self-taught full-stack engineer, writing software since 2016. Sole technical owner of a $1M+ e-commerce operation since 2021. Designing for least-friction: ultra-fast, easy-to-use workflows that save hundreds of hours a month.</p>
      </section>

      <section class="resume-section">
        <h2>Experience</h2>
        <div class="job-head">
          <h3>East Coast Drywall Tools</h3>
          <div class="dates">Aug 2021 &ndash; Present</div>
        </div>
        <div class="job-title">Software Engineer</div>
        <ul>
          <li>Enabled 4x annual revenue growth, from $250K to over $1M in 12 months, by taking the company from no online presence to 25+ orders per day with integrated sales and fulfillment systems.</li>
          <li>Sole engineer for the e-commerce and logistics stack, in production since 2021 and operated daily by non-technical staff; gather requirements, write documentation, train staff, and maintain every system.</li>
          <li>Built <strong>Priceprint</strong> in 3 days: a barcode-scanning PWA that keeps retail shelf pricing in sync with Shopify and prints grouped labels through LabelLIVE. Saves dozens of hours weekly and nearly eliminates pricing errors.</li>
          <li>Built <strong>Flashpart</strong>, a guided photo-capture tool that creates Shopify products for hundreds of near-identical parts, cutting product creation time by up to 90%.</li>
          <li>Built <strong>Schematimaker</strong>, a tool that converts PDF part schematics into interactive HTML for the storefront, cutting creation time from hours to minutes.</li>
          <li>Built a <strong>profit tracker</strong> that unifies Amazon, eBay, and Shopify order data via REST APIs and calculates true margins after fees and shipping, cutting manual reporting work by more than 50%.</li>
          <li>Handled all IT and infrastructure for the operation, including hardware upgrades, software rollouts, and internal support.</li>
        </ul>
      </section>

      <section class="resume-section">
        <h2>Projects</h2>
        <div class="project">
          <h3>Homelab.</h3>
          <p>Long-running Ubuntu infrastructure: Dokploy, GitHub Actions deployments, Docker services, Home Assistant, Pi-hole, and custom apps I build and operate end to end.</p>
        </div>
        <div class="project">
          <h3>Invokify.</h3>
          <p>Open-source Python library that turns decorated functions into parsable CLI commands; published on PyPI.</p>
        </div>
      </section>

      <section class="resume-section">
        <h2>Skills</h2>
        <dl class="skills-grid">
          <dt>Languages</dt>
          <dd><span class="skill-chip">TypeScript</span><span class="skill-chip">JavaScript</span><span class="skill-chip">Python</span><span class="skill-chip">SQL</span><span class="skill-chip">HTML/CSS</span></dd>
          <dt>Frameworks</dt>
          <dd><span class="skill-chip">React</span><span class="skill-chip">Node.js</span><span class="skill-chip">PWAs</span></dd>
          <dt>Data &amp; APIs</dt>
          <dd><span class="skill-chip">Convex</span><span class="skill-chip">SQLite</span><span class="skill-chip">PostgreSQL</span><span class="skill-chip">REST APIs</span><span class="skill-chip">Shopify / Amazon / eBay APIs</span></dd>
          <dt>Infrastructure</dt>
          <dd><span class="skill-chip">Docker</span><span class="skill-chip">Linux (Ubuntu)</span><span class="skill-chip">GitHub Actions (CI/CD)</span><span class="skill-chip">Dokploy</span><span class="skill-chip">Vercel</span></dd>
          <dt>Workflow</dt>
          <dd><span class="skill-chip">Git / GitHub</span><span class="skill-chip">Agentic development (Cursor)</span><span class="skill-chip">Least-friction UX design</span></dd>
        </dl>
      </section>

      <section class="resume-section">
        <h2>Education</h2>
        <div class="job-head">
          <h3>Homeschool High School Diploma <span class="edu-note">/ Self-directed software education since 2016</span></h3>
          <div class="dates">Graduated 2020</div>
        </div>
      </section>
    </div>
  </article>

  <section class="section resume-contact-section">
    <div class="section-title section-title--divider section-title--centered">
      <div class="section-title__group">
        <span class="section-title__line" aria-hidden="true"></span>
        <h2 class="section-title__heading">Contact</h2>
        <span class="section-title__line" aria-hidden="true"></span>
      </div>
    </div>
    <ContactForm client:load />
  </section>
</Layout>

<script>
  document.getElementById('print-resume')?.addEventListener('click', () => {
    const iframe = document.createElement('iframe');
    iframe.className = 'resume-print-frame';
    iframe.src = '/resume.pdf';
    iframe.setAttribute('aria-hidden', 'true');
    iframe.tabIndex = -1;
    document.body.appendChild(iframe);

    const cleanup = () => iframe.remove();

    iframe.addEventListener('load', () => {
      const frameWindow = iframe.contentWindow;
      if (!frameWindow) {
        cleanup();
        return;
      }

      frameWindow.focus();
      frameWindow.print();
      frameWindow.addEventListener('afterprint', cleanup, { once: true });
      window.setTimeout(cleanup, 60_000);
    }, { once: true });
  });
</script>

<style>
  .resume {
    padding: 2rem 0 0;
  }

  .resume-contact-section {
    padding-top: 2rem;
    padding-bottom: 0;
  }

  .resume-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .resume-toolbar .button {
    font-size: 0.9rem;
  }

  .resume-print-frame {
    position: fixed;
    width: 0;
    height: 0;
    border: 0;
    clip: rect(0, 0, 0, 0);
    overflow: hidden;
  }

  .resume-page {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: clamp(2rem, 6vw, 4rem) clamp(1.5rem, 6vw, 3.75rem);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text);
  }

  /* ---------- Header ---------- */

  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-bottom: 3px solid var(--accent);
    padding-bottom: 1.5rem;
  }

  .resume-header h1 {
    font-size: clamp(2.25rem, 5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .resume-role {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: 0.4rem;
    letter-spacing: 0.01em;
  }

  .resume-contact {
    text-align: right;
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.9;
  }

  .resume-contact a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .resume-contact a:hover {
    color: var(--accent);
  }

  .resume-contact .sep {
    color: var(--accent);
    padding: 0 0.35rem;
    font-weight: 600;
  }

  /* ---------- Sections ---------- */

  .resume-section {
    margin-top: 2.75rem;
  }

  .resume-section h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin: 0 0 1.25rem;
  }

  .resume-section h2::before {
    content: '';
    width: 1.5rem;
    height: 4px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  .resume-section h2::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .resume-summary p {
    font-size: 1.1rem;
    line-height: 1.75;
    margin: 0;
  }

  /* ---------- Experience ---------- */

  .job-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .job-head h3 {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .job-title {
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .edu-note {
    font-weight: 500;
    font-size: 1rem;
    color: var(--muted);
  }

  .dates {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    white-space: nowrap;
  }

  .resume-section ul {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .resume-section li {
    padding-left: 0.35rem;
  }

  .resume-section li::marker {
    color: var(--accent);
  }

  .resume-section li strong {
    color: var(--accent);
    font-weight: 650;
  }

  /* ---------- Projects ---------- */

  .project {
    margin-bottom: 1rem;
  }

  .project:last-child {
    margin-bottom: 0;
  }

  .project h3 {
    display: inline;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .project p {
    display: inline;
    margin: 0;
    color: var(--muted);
  }

  /* ---------- Skills ---------- */

  .skills-grid {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) 1fr;
    row-gap: 1rem;
    align-items: baseline;
    margin: 0;
  }

  .skills-grid dt {
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin: 0;
  }

  .skills-grid dd {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin: 0;
  }

  .skill-chip {
    position: relative;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0 0.35rem 0.3rem;
    white-space: nowrap;
    color: var(--text);
  }

  .skill-chip::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--text) 55%, transparent), transparent);
    print-color-adjust: exact;
    -webkit-print-color-adjust: exact;
  }

  /* ---------- Responsive ---------- */

  @media (max-width: 640px) {
    .resume {
      padding-top: 1rem;
    }

    .resume-contact {
      text-align: left;
      width: 100%;
      line-height: 1.7;
    }

    .resume-section {
      margin-top: 2.25rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
      row-gap: 0.4rem;
    }

    .skills-grid dt {
      margin-top: 0.75rem;
    }

    .skills-grid dt:first-of-type {
      margin-top: 0;
    }
  }

  /* ---------- Print ---------- */

  @media print {
    .resume {
      max-width: none;
      padding: 0;
    }

    .resume-toolbar {
      display: none;
    }

    .resume-page {
      border: none;
      border-radius: 0;
      padding: 0;
      background: #fff;
      color: #1c1c1c;
      font-size: 10pt;
      line-height: 1.45;
    }

    .resume-header {
      padding-bottom: 11pt;
    }

    .resume-header h1 {
      font-size: 24pt;
    }

    .resume-role {
      font-size: 11.5pt;
      margin-top: 2pt;
    }

    .resume-contact {
      font-size: 9pt;
      line-height: 1.6;
    }

    .resume-contact,
    .resume-contact a,
    .job-title,
    .dates,
    .edu-note,
    .project p {
      color: #5b5b5b;
    }

    .resume-section {
      margin-top: 11pt;
    }

    .resume-section h2 {
      font-size: 10pt;
      margin-bottom: 5pt;
    }

    .resume-section h2::after {
      background: #e4e4e4;
    }

    .resume-summary p {
      font-size: 10.25pt;
      line-height: 1.45;
    }

    .job-head {
      flex-wrap: nowrap;
    }

    .job-head h3 {
      font-size: 12pt;
      flex: 1;
      min-width: 0;
    }

    .edu-note {
      font-size: 9pt;
    }

    .dates {
      font-size: 8.5pt;
      flex-shrink: 0;
    }

    .job-title {
      font-size: 10.5pt;
      margin-top: 1pt;
    }

    .resume-section:last-child {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .resume-section ul {
      margin-top: 5pt;
      gap: 3.8pt;
    }

    .resume-section li strong {
      color: inherit;
    }

    .project {
      margin-bottom: 4pt;
    }

    .project h3 {
      font-size: 10.5pt;
    }

    .skills-grid {
      grid-template-columns: 92pt 1fr;
      row-gap: 4pt;
    }

    .skills-grid dt {
      font-size: 8.7pt;
    }

    .skills-grid dd {
      gap: 3pt 8pt;
    }

    .skill-chip {
      font-size: 8.7pt;
      padding: 0 4pt 2.5pt;
    }

    .skill-chip::after {
      background: linear-gradient(90deg, transparent, rgba(28, 28, 28, 0.6), transparent);
    }
  }

  @page {
    size: letter;
    margin: 0.45in 0.6in;
  }
</style>

<style is:global>
  @media print {
    .floating-nav,
    .site-footer,
    footer,
    .resume-contact-section {
      display: none !important;
    }

    body {
      padding: 0 !important;
      background: #fff !important;
      color: #1c1c1c !important;
    }
  }
</style>
