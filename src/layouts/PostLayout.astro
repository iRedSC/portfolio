---
import Layout from './Layout.astro';
import PostBanner from '../components/PostBanner.astro';
import PostToc from '../components/PostToc.astro';
import TocScrollSpy from '../components/TocScrollSpy';
import type { ImageMetadata } from 'astro';

type TocItem = {
	depth: number;
	slug: string;
	text: string;
};

type Props = {
	title: string;
	description?: string;
	image?: ImageMetadata;
	thumbnail?: ImageMetadata;
	publishedDate: Date;
	readingTime?: string;
	toc?: TocItem[];
	backgroundVideo?: string;
};

const { title, description, image, thumbnail, publishedDate, readingTime, toc = [], backgroundVideo } =
	Astro.props;
const bannerImage = thumbnail ?? image;
const socialImage = thumbnail ?? image;
---

<Layout title={title} description={description} image={socialImage}>
	{backgroundVideo ? (
		<div class="post-with-video">
			<div class="video-background" aria-hidden>
				<video src={backgroundVideo} autoplay muted loop playsinline />
			</div>
			<div class="video-overlay" aria-hidden />
		<article class:list={['post', bannerImage && 'post--has-banner']}>
			{bannerImage && <PostBanner src={bannerImage} />}
			<header class="post-hero">
				<div class="post-hero-content">
					<p class="eyebrow">{publishedDate.toLocaleDateString()}</p>
					<h1>{title}</h1>
					{description && <p class="lead">{description}</p>}
					{readingTime && <p class="meta">{readingTime}</p>}
				</div>
			</header>
				<div class="post-body">
					{toc.length > 0 && <PostToc items={toc} />}
					<div class="post-content"><slot /></div>
				</div>
			</article>
		</div>
	) : (
		<article class:list={['post', bannerImage && 'post--has-banner']}>
			{bannerImage && <PostBanner src={bannerImage} />}
			<header class="post-hero">
				<div class="post-hero-content">
					<p class="eyebrow">{publishedDate.toLocaleDateString()}</p>
					<h1>{title}</h1>
					{description && <p class="lead">{description}</p>}
					{readingTime && <p class="meta">{readingTime}</p>}
				</div>
			</header>
			<div class="post-body">
				{toc.length > 0 && <PostToc items={toc} />}
				<div class="post-content"><slot /></div>
			</div>
		</article>
	)}
	{toc.length > 0 && <TocScrollSpy client:load />}
</Layout>
